{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-pnpm.sh"
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-page-goto.sh"
					},
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dark-prefix.sh"
					},
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-opacity-tints.sh"
					},
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-directional-classes.sh"
					},
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/suggest-url-state.sh"
					},
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/suggest-test-selectors.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-save.sh",
						"timeout": 30
					}
				]
			}
		]
	}
}
