{
	"name": "sunlo-tanstack",
	"version": "0.23.0",
	"private": false,
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"scan": "vite --host & pnpx react-scan@latest localhost:5173",
		"build": "vite build",
		"lint": "oxlint . && eslint .",
		"preview": "vite preview",
		"format": "oxfmt . && prettier --write 'supabase/**/*.sql'",
		"check": "tsc -b",
		"format:check": "oxfmt --check . && prettier --check 'supabase/**/*.sql'",
		"scene": "scenetest --no-panel",
		"scene:ui": "scenetest",
		"scene:ci": "scenetest --no-panel --format both --report scenetest/.reports",
		"test": "playwright test",
		"test:unit": "vitest run",
		"test:nav": "SKIP_DB_RESET=1 playwright test e2e/navigations e2e/example.spec.ts e2e/login-flow.spec.ts --fully-parallel",
		"test-quick": "SKIP_DB_RESET=1 playwright test --ui e2e/navigations e2e/example.spec.ts e2e/login-flow.spec.ts --fully-parallel",
		"test:ui": "playwright test --ui",
		"test:chromium": "playwright test --project=chromium",
		"test:firefox": "playwright test --project=firefox",
		"test:webkit": "playwright test --project=webkit",
		"migrate": "supabase db diff --use-pg-delta -f new_migration",
		"types": "supabase gen types typescript --local > ./src/types/supabase.ts",
		"seeds:data": "supabase db dump --data-only --local > supabase/seed.sql",
		"seeds:schema": "supabase db dump --local > supabase/schemas/base.sql",
		"db-reset": "supabase db reset",
		"db-schema": "pnpm run seeds:schema && pnpm types && oxfmt ./src/types/supabase.ts && prettier --write 'supabase/**/*.sql'",
		"db-full": "supabase db reset && `pnpm run db-schema",
		"prepare": "husky"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@fontsource/atkinson-hyperlegible": "^5.2.8",
		"@fontsource/opendyslexic": "^5.2.5",
		"@hookform/resolvers": "^5.2.2",
		"@supabase/supabase-js": "^2.87.3",
		"@tanstack/db": "^0.6.5",
		"@tanstack/intent": "^0.0.29",
		"@tanstack/query-core": "^5.90.12",
		"@tanstack/query-db-collection": "^1.0.36",
		"@tanstack/react-db": "^0.1.83",
		"@tanstack/react-query": "^5.90.12",
		"@tanstack/react-router": "^1.159.5",
		"class-variance-authority": "^0.7.1",
		"cmdk": "1.1.1",
		"dayjs": "^1.11.19",
		"lucide-react": "^0.544.0",
		"qrcode.react": "^4.2.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hook-form": "^7.68.0",
		"react-markdown": "^10.1.0",
		"recharts": "^3.7.0",
		"sonner": "^1.7.0",
		"tailwind-oklch": "^0.5.0",
		"tailwindcss-animate": "^1.0.7",
		"vaul": "^1.1.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.58.2",
		"@prettier/plugin-oxc": "^0.1.3",
		"@scenetest/checks-panel": "^0.8.2",
		"@scenetest/checks-react": "^0.8.2",
		"@scenetest/scenes": "^0.8.2",
		"@scenetest/vite-plugin": "^0.8.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/line-clamp": "^0.4.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@tanstack/router-devtools": "^1.159.5",
		"@tanstack/router-plugin": "^1.159.5",
		"@types/node": "^22.19.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.50.0",
		"@vitejs/plugin-react": "^5.2.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.2",
		"eslint-plugin-oxlint": "^1.33.0",
		"eslint-plugin-react-hooks": "^6.0.0",
		"eslint-plugin-react-refresh": "^0.4.25",
		"globals": "^15.15.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.33.0",
		"playwright": "^1.58.2",
		"prettier": "^3.6.0",
		"prettier-plugin-sql": "^0.19.2",
		"tailwind-merge": "^2.6.0",
		"tailwindcss": "^4.1.18",
		"ts-fsrs": "4.7.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.50.0",
		"vite": "^7.3.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.18"
	},
	"optionalDependencies": {
		"supabase": "^2.76.14"
	},
	"packageManager": "pnpm@10.25.0",
	"pnpm": {
		"overrides": {
			"rollup": ">=4.59.0"
		}
	}
}
