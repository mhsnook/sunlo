{
	"name": "sunlo-tanstack",
	"version": "0.28.0",
	"private": false,
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"dev:local": "VITE_CHAT_USE_MOCK=true vite --host",
		"scan": "vite --host & pnpx react-scan@latest localhost:5173",
		"build": "vite build",
		"build:test": "VITE_CHAT_USE_MOCK=true SCENETEST_PANEL=0 vite build",
		"lint": "oxlint . && eslint .",
		"preview": "vite preview",
		"format": "oxfmt . && prettier --write 'supabase/**/*.sql'",
		"check": "tsc -b",
		"format:check": "oxfmt --check . && prettier --check 'supabase/**/*.sql'",
		"scene": "scenetest --no-panel",
		"scene:ui": "scenetest",
		"scene:ci": "scenetest --no-panel --format both --report scenetest/.reports",
		"st:link": "pnpm link ../scenetest-js/packages/scenes && pnpm link ../scenetest-js/packages/vite-plugin && pnpm link ../scenetest-js/packages/checks",
		"st:unlink": "pnpm unlink @scenetest/scenes @scenetest/vite-plugin @scenetest/checks && pnpm install",
		"test:unit": "vitest run",
		"migrate": "supabase db diff --use-pg-delta -f new_migration",
		"types": "supabase gen types typescript --local > ./src/types/supabase.ts",
		"seeds:data": "deno run --allow-env --allow-net --allow-read --allow-write --allow-run=cp scripts/dump-new-seeds.ts",
		"seeds:corpus": "deno run --allow-env --allow-net --allow-read --allow-write scripts/dump-new-seeds.ts --corpus-only",
		"db-reseed": "deno run --allow-env --allow-read --allow-run=docker scripts/dump-new-seeds.ts --reseed",
		"seeds:schema": "supabase db dump --local > supabase/schemas/base.sql",
		"db-reset": "supabase db reset",
		"db-schema": "pnpm run seeds:schema && pnpm types && oxfmt ./src/types/supabase.ts && prettier --write 'supabase/**/*.sql'",
		"db-full": "supabase db reset && `pnpm run db-schema",
		"prepare": "husky"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
		"@fontsource/opendyslexic": "^5.2.5",
		"@supabase/supabase-js": "^2.106.0",
		"@tanstack/db": "^0.6.5",
		"@tanstack/intent": "^0.0.29",
		"@tanstack/query-core": "^5.90.12",
		"@tanstack/query-db-collection": "^1.0.36",
		"@tanstack/react-db": "^0.1.83",
		"@tanstack/react-form": "^1.29.1",
		"@tanstack/react-query": "^5.90.12",
		"@tanstack/react-router": "1.170.4",
		"class-variance-authority": "^0.7.1",
		"cmdk": "1.1.1",
		"dayjs": "^1.11.19",
		"lucide-react": "^0.544.0",
		"qrcode.react": "^4.2.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-markdown": "^10.1.0",
		"recharts": "^3.7.0",
		"sonner": "^1.7.0",
		"tailwind-oklch": "github:mhsnook/tailwind-oklch#main",
		"tailwindcss-animate": "^1.0.7",
		"vaul": "^1.1.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.58.2",
		"@prettier/plugin-oxc": "^0.1.3",
		"@rolldown/plugin-babel": "^0.2.3",
		"@scenetest/checks": "^0.12.0",
		"@scenetest/scenes": "^0.10.0",
		"@scenetest/vite-plugin": "^0.12.0",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/line-clamp": "^0.4.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/react-query-devtools": "^5.100.10",
		"@tanstack/router-devtools": "1.167.0",
		"@tanstack/router-plugin": "1.168.6",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@vitejs/plugin-react": "^6.0.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"eslint": "^9.39.2",
		"eslint-plugin-oxlint": "^1.65.0",
		"eslint-plugin-react-hooks": "^6.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"oxfmt": "^0.50.0",
		"oxlint": "^1.65.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.3",
		"prettier-plugin-sql": "^0.20.0",
		"tailwind-merge": "^2.6.0",
		"tailwindcss": "^4.3.0",
		"ts-fsrs": "4.7.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	},
	"optionalDependencies": {
		"supabase": "^2.76.14"
	},
	"packageManager": "pnpm@10.25.0"
}
