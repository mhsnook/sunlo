# Embedding API configuration for edge functions
# Copy to .env and fill in your values:
#   cp supabase/functions/.env.example supabase/functions/.env

# --- Cloudflare Workers AI (recommended) ---
# Free tier: 10,000 neurons/day. Uses bge-m3 (multilingual, 1024 dims).
# Get your account ID: https://dash.cloudflare.com → any domain → Overview → right sidebar
# Create an API token: https://dash.cloudflare.com/profile/api-tokens (Workers AI → Read)
EMBEDDING_API_URL="https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1/embeddings"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="@cf/baai/bge-m3"

# --- OpenRouter (alternative) ---
# EMBEDDING_API_URL="https://openrouter.ai/api/v1/embeddings"
# EMBEDDING_API_KEY=""
# EMBEDDING_MODEL="qwen/qwen3-embedding-8b"
