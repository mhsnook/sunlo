# cp .env.example .env
VITE_SUPABASE_URL="http://localhost:54321"
VITE_SUPABASE_ANON_KEY=""
# used for playwright e2e tests
SUPABASE_SERVICE_ROLE_KEY=""

# Embedding API for semantic search (OpenAI-compatible endpoint)
EMBEDDING_API_URL="https://openrouter.ai/api/v1/embeddings"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="qwen/qwen3-embedding-8b"
# Set to "true" to enable hybrid semantic+trigram search
VITE_ENABLE_SEMANTIC_SEARCH=""

# Build/deploy details
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
APPLE_DEVELOPMENT_TEAM="app.sunlo.dev"
